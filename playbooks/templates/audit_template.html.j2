<!DOCTYPE html>
<html>
<head>
    <title>CIS Audit Report: {{ inventory_hostname }}</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 40px; background: #f0f2f5; }
        .card { background: white; padding: 25px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1 { color: #1a73e8; border-bottom: 2px solid #e8eaed; padding-bottom: 10px; }
        .meta { color: #5f6368; margin-bottom: 20px; }
        pre { 
            background: #202124; 
            color: #bdc1c6; 
            padding: 20px; 
            border-radius: 5px; 
            overflow-x: auto; 
            white-space: pre-wrap; 
            font-size: 14px;
            line-height: 1.5;
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>CIS Compliance Report</h1>
        <div class="meta">
            <strong>Server:</strong> {{ inventory_hostname }}<br>
            <strong>Report Generated (EST):</strong> {{ now(tz='America/New_York', fmt='%Y-%m-%d %H:%M:%S') }}
        </div>

        <pre>
{# 
  This regex looks for the 'Execution Date:' pattern and replaces the 
  timestamp with the current time from the Ansible controller.
#}
{{ raw_audit_content.stdout | regex_replace('Execution Date:\s+\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}', 'Execution Date:     ' ~ now(tz='America/New_York', fmt='%Y-%m-%d %H:%M:%S')) }}
        </pre>
    </div>
</body>
</html>